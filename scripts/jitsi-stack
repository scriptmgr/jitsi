# @@Copyright        :  Copyright: (c) 2026 Jason Hempstead, Casjays Developments
# @@Created          :  Tuesday, May 19, 2026 09:29 EDT
# @@File             :  jitsi-stack
# @@Description      :  Manage the Jitsi Meet Docker stack
# @@Changelog        :  Initial version — extracted from install.sh
# @@TODO             :
# @@Other            :
# @@Resource         :
# @@Terminal App     :  yes
# @@sudo/root        :  no
# @@Template         :  shell/bash
# - - - - - - - - - - - - - - - - - - - - - - - - -
# shellcheck disable=SC1001,SC1003,SC2001,SC2003,SC2016,SC2031,SC2090,SC2115,SC2120,SC2155,SC2199,SC2229,SC2317,SC2329
# - - - - - - - - - - - - - - - - - - - - - - - - -

APPNAME="${0##*/}"
VERSION="YYYYMMDDHHMM-git"
RUN_USER="${USER:-$(id -un)}"
SET_UID="${UID:-$(id -u)}"
SCRIPT_SRC_DIR="${BASH_SOURCE[0]%/*}"

# Suppress shellcheck unused warnings on standard boilerplate
export RUN_USER SET_UID SCRIPT_SRC_DIR

set -euo pipefail

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Configuration
# - - - - - - - - - - - - - - - - - - - - - - - - -

JITSISTACK_BASE_DIR="${JITSI_BASE_DIR:-/opt/jitsi}"
JITSISTACK_COMPOSE_FILE="${JITSISTACK_BASE_DIR}/docker-compose.yml"
JITSISTACK_ENV_FILE="${JITSISTACK_BASE_DIR}/.env"
JITSISTACK_BACKUP_DIR="${JITSISTACK_BASE_DIR}/backup"
JITSISTACK_DEBUG="${JITSISTACK_DEBUG:-0}"

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Standard utility functions (from script_conventions.md)
# - - - - - - - - - - - - - - - - - - - - - - - - -

__determine_hostname_name() {
  local fqdn
  fqdn="$(hostname -f 2>/dev/null)"
  if [[ -n "$fqdn" ]]; then
    printf '%s\n' "$fqdn"
    return 0
  fi
  return 1
}

__does_host_have_valid_ip6() {
  local addr
  addr="$(ip -6 addr show scope global 2>/dev/null | awk '/inet6/ {print $2; exit}')"
  [[ -n "$addr" ]] && return 0
  return 1
}

__is_ip4_public() {
  local ip="${1:-}"
  [[ -z "$ip" ]] && return 1
  [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1
  local a b c d
  IFS='.' read -r a b c d <<< "$ip"
  : "${d}"  # d is parsed for completeness but only a/b/c are tested
  (( a == 0 )) && return 1
  (( a == 10 )) && return 1
  (( a == 127 )) && return 1
  (( a == 100 && b >= 64 && b <= 127 )) && return 1
  (( a == 169 && b == 254 )) && return 1
  (( a == 172 && b >= 16 && b <= 31 )) && return 1
  (( a == 192 && b == 0 && c == 0 )) && return 1
  (( a == 192 && b == 0 && c == 2 )) && return 1
  (( a == 192 && b == 168 )) && return 1
  (( a == 198 && b == 51 && c == 100 )) && return 1
  (( a == 203 && b == 0 && c == 113 )) && return 1
  (( a >= 224 )) && return 1
  return 0
}

__get_hosts_ip4_address() {
  if [[ -n "${IP4_ADDRESS:-}" ]]; then
    printf '%s\n' "$IP4_ADDRESS"
    return 0
  fi
  local ip url
  for url in "https://ifcfg.us/ip" "https://ifconfig.co/ip" "https://checkip.amazonaws.com"; do
    ip="$(curl -4 -q -LSs --max-time 5 "$url" 2>/dev/null | tr -d '[:space:]')"
    if [[ -n "$ip" ]] && __is_ip4_public "$ip"; then
      printf '%s\n' "$ip"
      return 0
    fi
  done
  return 1
}

__is_ip6_public() {
  local ip="${1:-}"
  [[ -z "$ip" ]] && return 1
  ip="${ip%%\%*}"
  local low="${ip,,}"
  [[ "$low" == "::" || "$low" == "::1" ]] && return 1
  [[ "$low" =~ ^fe[89ab][0-9a-f]?: ]] && return 1
  [[ "$low" =~ ^f[cd] ]] && return 1
  [[ "$low" =~ ^::ffff: ]] && return 1
  [[ "$low" =~ ^[23] ]] || return 1
  return 0
}

__get_hosts_ip6_address() {
  __does_host_have_valid_ip6 || return 1
  if [[ -n "${IP6_ADDRESS:-}" ]]; then
    printf '%s\n' "$IP6_ADDRESS"
    return 0
  fi
  local ip url
  for url in "https://ifcfg.us/ip" "https://ifconfig.co/ip" "https://api6.ipify.org"; do
    ip="$(curl -6 -q -LSs --max-time 5 "$url" 2>/dev/null | tr -d '[:space:]')"
    if [[ -n "$ip" ]] && __is_ip6_public "$ip"; then
      printf '%s\n' "$ip"
      return 0
    fi
  done
  return 1
}

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Utility functions
# - - - - - - - - - - - - - - - - - - - - - - - - -

__die()      { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
__info()     { printf 'INFO:  %s\n' "$*"; }
__warn()     { printf 'WARN:  %s\n' "$*" >&2; }
__need_cmd() { command -v "$1" &>/dev/null; }

__require_installed() {
  [[ -f "${JITSISTACK_COMPOSE_FILE}" ]] || __die "Jitsi not installed. Run install.sh first."
}

# Wrapper: prefers docker compose plugin, falls back to docker-compose.
# Detection is cached in JITSISTACK_COMPOSE_CMD on first call.
JITSISTACK_COMPOSE_CMD=""
__docker_compose() {
  if [[ -z "${JITSISTACK_COMPOSE_CMD}" ]]; then
    if docker compose version >/dev/null 2>&1; then
      JITSISTACK_COMPOSE_CMD="plugin"
    elif command -v docker-compose >/dev/null 2>&1; then
      JITSISTACK_COMPOSE_CMD="legacy"
    else
      __die "Neither 'docker compose' plugin nor 'docker-compose' is available."
    fi
  fi
  case "${JITSISTACK_COMPOSE_CMD}" in
    plugin) docker compose -f "${JITSISTACK_COMPOSE_FILE}" "$@" ;;
    legacy) docker-compose -f "${JITSISTACK_COMPOSE_FILE}" "$@" ;;
  esac
}

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Help and version
# - - - - - - - - - - - - - - - - - - - - - - - - -

__help() {
  cat <<EOF
${APPNAME} v${VERSION} — Manage the Jitsi Meet Docker stack

Usage: ${APPNAME} [OPTIONS] <command> [args...]

Commands:
  start              Pull images and start all containers
  stop               Stop all containers (preserves data)
  restart            Restart all containers
  status             Show container status and connection info
  logs [service]     Tail logs (all services or a named one)
  update             Pull latest images and restart
  backup             Backup config and data to a timestamped archive

Options:
  -h, --help       Show this help
  -v, --version    Show version
  --debug          Enable trace output
  --no-color       Disable color output

Environment:
  JITSI_BASE_DIR    Installation directory (default: /opt/jitsi)
  JITSISTACK_DEBUG  Set to 1 to enable trace output (same as --debug)
  NO_COLOR          Set to disable color output

Notes:
  The Prosody container binds on INTERNAL_PROXY_IP:HTTP_PORT (both read
  from \${JITSI_BASE_DIR}/.env). Terminate TLS with an external reverse
  proxy (nginx, Caddy, Traefik) and forward to that bind address.

Examples:
  ${APPNAME} start
  ${APPNAME} status
  ${APPNAME} logs prosody
  ${APPNAME} update
  ${APPNAME} backup
EOF
}

__version() {
  printf '%s\n' "${APPNAME} v${VERSION}"
}

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Stack commands
# - - - - - - - - - - - - - - - - - - - - - - - - -

__stack_start() {
  __info "Pulling latest images..."
  __docker_compose pull
  __info "Starting Jitsi stack..."
  __docker_compose up -d
  __info "Stack started."
}

__stack_stop() {
  __info "Stopping Jitsi stack..."
  __docker_compose stop
  __info "Stack stopped."
}

__stack_restart() {
  __info "Restarting Jitsi stack..."
  __docker_compose restart
  __info "Stack restarted."
}

__stack_status() {
  local public_url="" http_port="" internal_ip="" enable_auth="" enable_subdomain=""
  local key value line

  # Read key values from .env (skip comments/blanks, strip surrounding quotes)
  if [[ -f "${JITSISTACK_ENV_FILE}" ]]; then
    while IFS= read -r line || [[ -n "${line}" ]]; do
      # strip leading whitespace
      line="${line#"${line%%[![:space:]]*}"}"
      # skip blank lines and comments
      [[ -z "${line}" || "${line}" == \#* ]] && continue
      # split on first '='
      key="${line%%=*}"
      value="${line#*=}"
      # strip surrounding single or double quotes
      case "${value}" in
        \"*\") value="${value#\"}"; value="${value%\"}" ;;
        \'*\') value="${value#\'}"; value="${value%\'}" ;;
      esac
      case "${key}" in
        PUBLIC_URL)              public_url="${value}" ;;
        HTTP_PORT)               http_port="${value}" ;;
        INTERNAL_PROXY_IP)       internal_ip="${value}" ;;
        ENABLE_AUTH)             enable_auth="${value}" ;;
        ENABLE_SUBDOMAIN_ROOMS)  enable_subdomain="${value}" ;;
      esac
    done < "${JITSISTACK_ENV_FILE}"
  fi

  local fqdn ip4 ip6 bind
  fqdn="$(__determine_hostname_name 2>/dev/null || hostname)"
  ip4="$(__get_hosts_ip4_address 2>/dev/null || true)"
  ip6="$(__get_hosts_ip6_address 2>/dev/null || true)"

  # Compose the actual bind address (what Prosody listens on inside the host)
  if [[ -n "${internal_ip}" && -n "${http_port}" ]]; then
    bind="${internal_ip}:${http_port}"
  elif [[ -n "${http_port}" ]]; then
    bind="0.0.0.0:${http_port}"
  else
    bind=""
  fi

  printf '\n'
  printf '============================================================\n'
  printf 'Jitsi Meet Stack Status\n'
  printf '============================================================\n'
  printf 'Hostname:        %s\n' "${fqdn}"
  [[ -n "${ip4}" ]]              && printf 'IPv4:            %s\n' "${ip4}"
  [[ -n "${ip6}" ]]              && printf 'IPv6:            %s\n' "${ip6}"
  [[ -n "${public_url}" ]]       && printf 'Public URL:      %s\n' "${public_url}"
  [[ -n "${internal_ip}" ]]      && printf 'Internal IP:     %s\n' "${internal_ip}"
  [[ -n "${http_port}" ]]        && printf 'HTTP Port:       %s\n' "${http_port}"
  [[ -n "${bind}" ]]             && printf 'Bind Address:    %s\n' "${bind}"
  [[ -n "${enable_auth}" ]]      && printf 'Auth Required:   %s\n' "${enable_auth}"
  [[ -n "${enable_subdomain}" ]] && printf 'Subdomain Rooms: %s\n' "${enable_subdomain}"
  printf '------------------------------------------------------------\n'
  if [[ -f "${JITSISTACK_COMPOSE_FILE}" ]]; then
    __docker_compose ps
  else
    __warn "Stack not installed at ${JITSISTACK_BASE_DIR} — run install.sh first."
  fi
  printf '\n'
}

__stack_logs() {
  local service="${1:-}"
  if [[ -n "${service}" ]]; then
    __docker_compose logs -f "${service}"
  else
    __docker_compose logs -f
  fi
}

__stack_update() {
  __info "Pulling latest images..."
  __docker_compose pull
  __info "Restarting with updated images..."
  __docker_compose up -d
  __info "Update complete."
}

__stack_backup() {
  __need_cmd tar || __die "tar is not installed or not in PATH."

  local ts archive tar_log rc
  ts="$(date +%Y%m%d-%H%M%S)"
  archive="${JITSISTACK_BACKUP_DIR}/jitsi-backup-${ts}.tar.gz"
  mkdir -p "${JITSISTACK_BACKUP_DIR}"

  # Backups may contain .env with secrets — restrict to owner only
  ( umask 077 && : > "${archive}" ) || __die "Cannot create backup file: ${archive}"

  tar_log="$(mktemp -t "jitsi-stack-backup-XXXXXX.log")"
  # Always remove the log on exit from this function
  trap 'rm -f "${tar_log}"' RETURN

  __info "Creating backup: ${archive}"
  # Exclude the backup dir itself (avoid recursion) and transient runtime state.
  # tar exit code 1 = "some files changed during read" — acceptable on a live stack.
  set +e
  tar --create --gzip \
    --file="${archive}" \
    -C "${JITSISTACK_BASE_DIR}" \
    --exclude='./backup' \
    --exclude='./backup/*' \
    --exclude='./*.tar.gz' \
    . 2>"${tar_log}"
  rc=$?
  set -e

  if (( rc == 0 )); then
    __info "Backup saved: ${archive}"
  elif (( rc == 1 )); then
    __warn "Backup completed with warnings (files changed during read): ${archive}"
    [[ -s "${tar_log}" ]] && sed 's/^/  tar: /' "${tar_log}" >&2
  else
    __warn "tar exited with status ${rc}"
    [[ -s "${tar_log}" ]] && sed 's/^/  tar: /' "${tar_log}" >&2
    __die "Backup failed: ${archive}"
  fi
}

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Entry point
# - - - - - - - - - - - - - - - - - - - - - - - - -

__main() {
  __need_cmd docker || __die "docker is not installed or not in PATH."

  local cmd="${1:-}"
  [[ -n "${cmd}" ]] && shift

  # No command → show help and exit non-zero
  if [[ -z "${cmd}" ]]; then
    __help
    exit 1
  fi

  # status renders even when the stack isn't installed; all other commands need it
  [[ "${cmd}" != "status" ]] && __require_installed

  case "${cmd}" in
    start)    __stack_start ;;
    stop)     __stack_stop ;;
    restart)  __stack_restart ;;
    status)   __stack_status ;;
    logs)     __stack_logs "$@" ;;
    update)   __stack_update ;;
    backup)   __stack_backup ;;
    *)        __die "Unknown command: ${cmd}. Use: start, stop, restart, status, logs, update, backup" ;;
  esac
}

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Argument parsing
# - - - - - - - - - - - - - - - - - - - - - - - - -

# Require GNU getopt (the -T probe returns 4 on enhanced/GNU getopt)
__getopt_rc=0
getopt -T >/dev/null 2>&1 || __getopt_rc=$?
(( __getopt_rc == 4 )) || __die "GNU getopt is required (util-linux). Install it via your package manager."
unset __getopt_rc

_OPTS="$(getopt -o hv -l help,version,debug,no-color -n "${APPNAME}" -- "$@")" \
  || { __help; exit 1; }
eval set -- "${_OPTS}"
while true; do
  case "$1" in
    -h|--help)    __help; exit 0 ;;
    -v|--version) __version; exit 0 ;;
    --debug)      JITSISTACK_DEBUG=1; shift ;;
    --no-color)   export NO_COLOR=1; shift ;;
    --)           shift; break ;;
    *)            break ;;
  esac
done

[[ "${JITSISTACK_DEBUG}" == "1" ]] && set -x

__main "$@"

# ex: ts=2 sw=2 et filetype=sh
